# TradeCore production environment template.
# Copy to .env.production and fill in each secret. Never commit .env.production.
# Regenerate all secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# -------- App --------
APP_ENV=production
APP_SECRET_KEY=replace-with-64-hex-chars
FRONTEND_URL=https://app.tradecore.io

# -------- Encryption (Fernet) --------
# Generate once; rotating invalidates all stored exchange keys.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# -------- Database --------
POSTGRES_USER=tradecore
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=tradecore
DATABASE_URL=postgresql+asyncpg://tradecore:replace-with-strong-password@postgres:5432/tradecore
DATABASE_URL_SYNC=postgresql+psycopg2://tradecore:replace-with-strong-password@postgres:5432/tradecore

# -------- Redis --------
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_STORAGE_URL=redis://redis:6379/1

# -------- JWT --------
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# -------- Stripe --------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID_MONTHLY=price_...
STRIPE_PRO_PRICE_ID_YEARLY=price_...
STRIPE_ELITE_PRICE_ID_MONTHLY=price_...
STRIPE_ELITE_PRICE_ID_YEARLY=price_...

# -------- Google OAuth --------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------- Email --------
# Provider: "sendgrid" | "smtp" | "" (empty = dev stub, just logs).
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=no-reply@tradecore.io
EMAIL_FROM_NAME=TradeCore

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Generic SMTP (used when EMAIL_PROVIDER=smtp). Works with Gmail, Fastmail,
# Mailgun SMTP, self-hosted Postfix, etc.
#
# Gmail quickstart:
#   1. Enable 2-step verification on the sending Google account
#   2. https://myaccount.google.com/apppasswords — create an "App password"
#      (the 16-char one; NOT your real Google password)
#   3. Use settings below. EMAIL_FROM_ADDRESS must match SMTP_USER or be an
#      alias of it, otherwise Gmail rewrites the From header.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your.address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_TIMEOUT_SECONDS=10

# -------- Telegram notifications --------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false

# -------- External data providers --------
WHALE_ALERT_API_KEY=
COINGLASS_API_KEY=
COINGECKO_API_KEY=
TRADING_ECONOMICS_API_KEY=

# -------- Binance streams --------
BINANCE_STREAMS_ENABLED=true
