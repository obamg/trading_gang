# TradeCore production environment template.
# Copy to .env.production and fill in each secret. Never commit .env.production.
# Regenerate all secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# -------- App --------
APP_ENV=production
APP_SECRET_KEY=replace-with-64-hex-chars
FRONTEND_URL=https://app.tradecore.io

# -------- Encryption (Fernet) --------
# Generate once; rotating invalidates all stored exchange keys.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# -------- Database --------
POSTGRES_USER=tradecore
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=tradecore
DATABASE_URL=postgresql+asyncpg://tradecore:replace-with-strong-password@postgres:5432/tradecore
DATABASE_URL_SYNC=postgresql+psycopg2://tradecore:replace-with-strong-password@postgres:5432/tradecore

# -------- Redis --------
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_STORAGE_URL=redis://redis:6379/1

# -------- JWT --------
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# -------- Stripe --------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID_MONTHLY=price_...
STRIPE_PRO_PRICE_ID_YEARLY=price_...
STRIPE_ELITE_PRICE_ID_MONTHLY=price_...
STRIPE_ELITE_PRICE_ID_YEARLY=price_...

# -------- Google OAuth --------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------- Email (SendGrid) --------
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@tradecore.io
EMAIL_FROM_NAME=TradeCore

# -------- Telegram notifications --------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false

# -------- External data providers --------
WHALE_ALERT_API_KEY=
COINGLASS_API_KEY=
COINGECKO_API_KEY=
TRADING_ECONOMICS_API_KEY=

# -------- Binance streams --------
BINANCE_STREAMS_ENABLED=true
