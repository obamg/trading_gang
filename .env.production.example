# TradeCore production environment template.
# Copy to .env.production and fill in each secret. Never commit .env.production.
# Regenerate all secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# -------- App --------
APP_ENV=production
APP_SECRET_KEY=replace-with-64-hex-chars
FRONTEND_URL=https://app.tradecore.io

# -------- Encryption (Fernet) --------
# Generate once; rotating invalidates all stored exchange keys.
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# -------- Database --------
POSTGRES_USER=tradecore
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=tradecore
DATABASE_URL=postgresql+asyncpg://tradecore:replace-with-strong-password@postgres:5432/tradecore
DATABASE_URL_SYNC=postgresql+psycopg2://tradecore:replace-with-strong-password@postgres:5432/tradecore

# -------- Redis --------
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_STORAGE_URL=redis://redis:6379/1

# -------- JWT --------
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# -------- Stripe --------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID_MONTHLY=price_...
STRIPE_PRO_PRICE_ID_YEARLY=price_...
STRIPE_ELITE_PRICE_ID_MONTHLY=price_...
STRIPE_ELITE_PRICE_ID_YEARLY=price_...

# -------- Google OAuth --------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------- Email --------
# Provider: "sendgrid" | "smtp" | "" (empty = dev stub, just logs).
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=no-reply@tradecore.io
EMAIL_FROM_NAME=TradeCore

# SendGrid (used when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Generic SMTP (used when EMAIL_PROVIDER=smtp). Works with Gmail, Fastmail,
# Mailgun SMTP, self-hosted Postfix, etc.
#
# Gmail quickstart:
#   1. Enable 2-step verification on the sending Google account
#   2. https://myaccount.google.com/apppasswords — create an "App password"
#      (the 16-char one; NOT your real Google password)
#   3. Use settings below. EMAIL_FROM_ADDRESS must match SMTP_USER or be an
#      alias of it, otherwise Gmail rewrites the From header.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your.address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_TIMEOUT_SECONDS=10

# -------- Telegram notifications --------
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false

# ============================================================
# EXTERNAL DATA PROVIDERS
# ============================================================
# Only fill keys for modules you're actually running. Leave the
# rest blank — the corresponding service will no-op or fall back
# to its free public endpoint. Signup links are inline.
# ============================================================

# -------- Exchanges (RadarX, LiquidMap, TradeLog, PerformanceCore) --------
# Free. Create READ-ONLY keys. No withdrawal permission, ever.
# Binance:   https://www.binance.com/en/my/settings/api-management
# Bybit:     https://www.bybit.com/app/user/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_STREAMS_ENABLED=true
BYBIT_API_KEY=
BYBIT_API_SECRET=
# Optional extras
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ============================================================
# V1 CORE BUNDLE (~$306/mo)
# ============================================================
# The minimum set of paid providers to run TradeCore in prod.
# Each entry replaces 1-2 overlapping services; see the
# "Optional / v2" block below for what was consolidated away.
# ============================================================

# -------- Market metadata (GemRadar, RadarX, Oracle) --------
# CoinGecko Pro "Analyst" $129/mo — https://www.coingecko.com/en/api/pricing
# Replaces CoinMarketCap. CG Pro also bundles GeckoTerminal (DEX data).
COINGECKO_API_KEY=
COINGECKO_PLAN=demo        # demo | analyst | lite | pro

# -------- Derivatives data (RadarX, LiquidMap) --------
# Coinglass Standard $29/mo — https://www.coinglass.com/pricing
# Aggregates funding / OI / liquidations across 20+ exchanges.
COINGLASS_API_KEY=

# -------- Block explorers (WhaleRadar, GemRadar) --------
# Free tier is enough — Alchemy Enhanced APIs (below) cover most on-chain
# queries. Keep these only for contract source verification.
# Etherscan: https://etherscan.io/myapikey  |  BscScan: https://bscscan.com/myapikey
# Arbiscan:  https://arbiscan.io/myapikey   |  Polygonscan: https://polygonscan.com/myapikey
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
ARBISCAN_API_KEY=
POLYGONSCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
BASESCAN_API_KEY=

# -------- Multichain RPC + Enhanced APIs (WhaleRadar, LiquidMap) --------
# Alchemy Growth $49/mo — https://dashboard.alchemy.com/
# One key for ETH/Polygon/Arbitrum/Optimism/Base/Solana.
# Replaces QuickNode. Enhanced APIs (getAssetTransfers, getTokenBalances)
# plus webhooks replace most Etherscan Pro and some Whale Alert usage.
ALCHEMY_API_KEY=
ALCHEMY_ETH_WSS=wss://eth-mainnet.g.alchemy.com/v2/REPLACE
ALCHEMY_POLYGON_WSS=wss://polygon-mainnet.g.alchemy.com/v2/REPLACE
ALCHEMY_ARBITRUM_WSS=wss://arb-mainnet.g.alchemy.com/v2/REPLACE
ALCHEMY_BASE_WSS=wss://base-mainnet.g.alchemy.com/v2/REPLACE
ALCHEMY_SOLANA_RPC=
ALCHEMY_SOLANA_WSS=
ALCHEMY_WEBHOOK_SIGNING_KEY=

# -------- Whale tracking (WhaleRadar) --------
# Whale Alert Personal $29.95/mo — https://whale-alert.io/pricing
# Keep for v1 speed-to-market; in v2 you can replace this with Alchemy
# webhooks + your own tagged-address list.
WHALE_ALERT_API_KEY=

# -------- Sentiment + on-chain social (SentimentPulse) --------
# Santiment Pro $49/mo    — https://app.santiment.net/pricing
# CryptoPanic Pro $20/mo  — https://cryptopanic.com/developers/api/
# Reddit: free            — https://www.reddit.com/prefs/apps
# Santiment replaces LunarCrush (social + on-chain in one API).
# CryptoPanic replaces Messari News (news aggregation + sentiment tags).
SANTIMENT_API_KEY=
CRYPTOPANIC_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=tradecore/1.0 by your_reddit_username

# -------- Macro (MacroPulse) --------
# FRED: free          — https://fred.stlouisfed.org/docs/api/api_key.html
# Alpha Vantage: free — https://www.alphavantage.co/support/#api-key
# DefiLlama: free     — https://defillama.com/docs/api  (no key needed)
# DefiLlama replaces Dune Plus for v1 (TVL / DEX volumes / yields / stables).
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ============================================================
# OPTIONAL / V2 — add only when a specific feature demands it
# ============================================================
# Each of these is consolidated into a V1 provider above.
# Uncomment and fill only if you hit the specific use case noted.

# CoinMarketCap Basic $79/mo — https://pro.coinmarketcap.com/
#   Only if you want a second metadata source for cross-validation.
# COINMARKETCAP_API_KEY=

# LunarCrush Individual $29/mo — https://lunarcrush.com/developers/api/pricing
#   Only if Santiment's social depth is insufficient for SentimentPulse.
# LUNARCRUSH_API_KEY=

# Messari Pro $29/mo — https://messari.io/api
#   Only for their research reports / protocol profiles (not news).
# MESSARI_API_KEY=

# QuickNode Build $49/mo — https://dashboard.quicknode.com/
#   Only if you need a second RPC for Solana-heavy workloads beyond Alchemy.
# QUICKNODE_SOLANA_RPC=
# QUICKNODE_SOLANA_WSS=

# Dune Plus $399/mo — https://dune.com/pricing
#   Only when LiquidMap v2 needs custom SQL against raw on-chain data.
# DUNE_API_KEY=

# Arkham (invite-only beta) — https://www.arkhamintelligence.com/
#   Only if accepted; free during beta. Entity labels for WhaleRadar.
# ARKHAM_API_KEY=

# Solscan Pro — https://pro-api.solscan.io/
#   Only if Alchemy Solana + free Solscan isn't enough.
# SOLSCAN_API_KEY=

# TradingEconomics $75/mo — https://tradingeconomics.com/api/
#   Only if FRED + Alpha Vantage don't cover the econ-calendar events you need.
# TRADING_ECONOMICS_API_KEY=

# X (Twitter) Basic $200/mo — https://developer.x.com/en/portal/products/basic
#   Skip for v1. Reddit + CryptoPanic covers ~70% of SentimentPulse without it.
# TWITTER_BEARER_TOKEN=

# ============================================================
# OBSERVABILITY / OPS
# ============================================================

# Sentry Team $26/mo — https://sentry.io/pricing/
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
