# TradeCore production environment — formationdouane.online
# Copy to .env.production and fill in values. Never commit .env.production.
#
# Deploy:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# ── Postgres ──
POSTGRES_USER=tradecore
POSTGRES_PASSWORD=CHANGE_ME          # strong random password
POSTGRES_DB=tradecore

# ── Secrets ──
# Generate each with: openssl rand -hex 32
JWT_SECRET=
APP_SECRET_KEY=
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Stripe (https://dashboard.stripe.com/apikeys) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID_MONTHLY=
STRIPE_PRO_PRICE_ID_YEARLY=
STRIPE_ELITE_PRICE_ID_MONTHLY=
STRIPE_ELITE_PRICE_ID_YEARLY=

# ── Google OAuth (https://console.cloud.google.com/apis/credentials) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (https://myaccount.google.com/apppasswords) ──
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=no-reply@formationdouane.online
EMAIL_FROM_NAME=TradeCore
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Market Data ──
# CoinGecko free tier (https://www.coingecko.com/en/api/pricing)
COINGECKO_API_KEY=
# Whale Alert (https://whale-alert.io/signup)
WHALE_ALERT_API_KEY=
# TradingEconomics (https://tradingeconomics.com/analytics/api.aspx)
TRADING_ECONOMICS_API_KEY=

# ── Binance (free, no key needed for public streams) ──
BINANCE_STREAMS_ENABLED=true

# ── Telegram (https://t.me/BotFather) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false

# ── Certbot ──
CERTBOT_EMAIL=your-email@example.com
