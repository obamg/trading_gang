# ========== Core ==========
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-64-char-string-in-production
FRONTEND_URL=http://localhost:5173

# ========== Database ==========
DATABASE_URL=postgresql+asyncpg://tradecore:tradecore@localhost:5432/tradecore
# Sync URL used by Alembic for migrations (same DB, psycopg2 driver)
DATABASE_URL_SYNC=postgresql+psycopg2://tradecore:tradecore@localhost:5432/tradecore

# ========== Redis ==========
REDIS_URL=redis://localhost:6379/0

# ========== JWT ==========
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7

# ========== Stripe ==========
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRO_PRICE_ID_MONTHLY=price_pro_monthly_placeholder
STRIPE_PRO_PRICE_ID_YEARLY=price_pro_yearly_placeholder
STRIPE_ELITE_PRICE_ID_MONTHLY=price_elite_monthly_placeholder
STRIPE_ELITE_PRICE_ID_YEARLY=price_elite_yearly_placeholder

# ========== Google OAuth ==========
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ========== Email (SendGrid) ==========
# In dev, leave SENDGRID_API_KEY empty — email links are printed to stdout instead
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@tradecore.local
EMAIL_FROM_NAME=TradeCore

# ========== Rate limiting ==========
RATE_LIMIT_STORAGE_URL=redis://localhost:6379/1

# ========== Binance (market data) ==========
BINANCE_BASE_URL=wss://fstream.binance.com
BINANCE_REST_URL=https://fapi.binance.com
BINANCE_MIN_QUOTE_VOLUME_USD=10000000
BINANCE_SYMBOL_REFRESH_MINUTES=60
# Set to true to enable streams on startup (disabled by default in dev)
BINANCE_STREAMS_ENABLED=false

# ========== Telegram ==========
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false
